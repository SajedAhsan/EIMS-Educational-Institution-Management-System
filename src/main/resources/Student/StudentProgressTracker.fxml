<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="760.0" prefWidth="1220.0" style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Student.StudentProgressTrackerController">

   <!-- ── Top header ───────────────────────────────────────────────────── -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12.0"
            style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-width: 0 0 1 0;"
            BorderPane.alignment="CENTER_LEFT">
         <padding><Insets bottom="12.0" left="16.0" right="16.0" top="12.0" /></padding>
         <children>
            <Button onAction="#handleBack" prefHeight="34.0" prefWidth="90.0"
                    style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold;"
                    text="← Back" />
            <Label text="Student Progress Tracker" textFill="#1f2937">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>
         </children>
      </HBox>
   </top>

   <!-- ── Left sidebar: course list ────────────────────────────────────── -->
   <left>
      <VBox prefWidth="250.0" spacing="10.0"
            style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-width: 0 1 0 0;">
         <padding><Insets bottom="14.0" left="12.0" right="12.0" top="14.0" /></padding>
         <children>
            <Label text="My Courses" textFill="#334155">
               <font><Font name="System Bold" size="15.0" /></font>
            </Label>
            <Label text="Click a course to view your progress" textFill="#64748b" wrapText="true" />
            <ListView fx:id="courseListView" prefHeight="640.0" />
         </children>
      </VBox>
   </left>

   <!-- ── Centre: scrollable stats panel ───────────────────────────────── -->
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                  style="-fx-background: transparent; -fx-background-color: transparent;">
         <content>
            <VBox spacing="14.0">
               <padding><Insets bottom="18.0" left="18.0" right="18.0" top="18.0" /></padding>
               <children>

                  <!-- Course title -->
                  <Label fx:id="selectedCourseLabel" text="Select a course from the left →"
                         textFill="#0f172a">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>

                  <Separator />

                  <!-- ── Attendance card ─────────────────────────────────── -->
                  <VBox spacing="8.0"
                        style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 8; -fx-background-radius: 8;">
                     <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                     <children>
                        <Label text="📅  Attendance" textFill="#1e3a5f">
                           <font><Font name="System Bold" size="15.0" /></font>
                        </Label>

                        <!-- shown when teacher has not yet marked any attendance -->
                        <Label fx:id="noAttendanceLabel"
                              text="No classes conducted yet."
                               textFill="#94a3b8" wrapText="true" />

                        <!-- shown once attendance exists -->
                        <Label fx:id="attendanceDetailsLabel" textFill="#475569" wrapText="true" />
                           <Label fx:id="attendanceWarningLabel" text="Warning: Attendance below 80%"
                              textFill="#dc2626" style="-fx-font-weight: bold;" wrapText="true" />

                        <!-- Pie chart: green = present, red = absent (colours applied in code) -->
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                           <children>
                              <PieChart fx:id="attendancePieChart" legendVisible="false"
                                        prefHeight="250.0" prefWidth="460.0" />
                              <VBox spacing="8.0"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #d7deea; -fx-border-radius: 8; -fx-background-radius: 8;">
                                 <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                                 <children>
                                    <Label text="Legend" textFill="#1f2937">
                                       <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <Label text="🟢 Green = Present %" textFill="#166534" />
                                    <Label text="🔴 Red = Absent %" textFill="#991b1b" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- ── Assignments card ────────────────────────────────── -->
                  <VBox spacing="8.0"
                        style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 8; -fx-background-radius: 8;">
                     <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                     <children>
                        <Label text="📝  Assignments" textFill="#1e3a5f">
                           <font><Font name="System Bold" size="15.0" /></font>
                        </Label>

                        <Label fx:id="noAssignmentsLabel"
                              text="No assignments given so far"
                               textFill="#94a3b8" />

                        <Label fx:id="assignmentsSummaryLabel" textFill="#475569" wrapText="true" />

                        <TableView fx:id="assignmentsTable" prefHeight="160.0">
                           <columns>
                              <TableColumn fx:id="colAssignmentTitle"  prefWidth="250.0" text="Assignment Name" />
                              <TableColumn fx:id="colAssignmentStatus" prefWidth="170.0" text="Status" />
                              <TableColumn fx:id="colAssignmentScore"  prefWidth="110.0" text="Score" />
                           </columns>
                        </TableView>

                        <BarChart fx:id="assignmentScoreBarChart" prefHeight="210.0" animated="true">
                           <xAxis><CategoryAxis label="Assignments" /></xAxis>
                           <yAxis><NumberAxis label="Score (0–100)" lowerBound="0.0" upperBound="100.0" tickUnit="10.0" /></yAxis>
                        </BarChart>

                        <Label fx:id="assignmentAverageLabel" text="Average Score: --" textFill="#1f2937">
                           <font><Font name="System Bold" size="13.0" /></font>
                        </Label>

                        <VBox fx:id="assignmentColorLegendBox" spacing="5.0"
                              style="-fx-background-color: #f8fafc; -fx-border-color: #d7deea; -fx-border-radius: 8; -fx-background-radius: 8;">
                           <padding><Insets bottom="8.0" left="10.0" right="10.0" top="8.0" /></padding>
                           <children>
                              <Label text="Legend" textFill="#1f2937">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <Label text="🔴 Red: Below 40" textFill="#991b1b" />
                              <Label text="🟡 Yellow: 40–60" textFill="#854d0e" />
                              <Label text="🟢 Green: 60–80" textFill="#166534" />
                              <Label text="🟣 Purple: Above 80" textFill="#7e22ce" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- ── Exams / Quizzes card ────────────────────────────── -->
                  <VBox spacing="8.0"
                        style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 8; -fx-background-radius: 8;">
                     <padding><Insets bottom="14.0" left="14.0" right="14.0" top="14.0" /></padding>
                     <children>
                        <Label text="📊  Exams / Quizzes" textFill="#1e3a5f">
                           <font><Font name="System Bold" size="15.0" /></font>
                        </Label>

                        <Label fx:id="noExamsLabel"
                               text="No exams taken so far."
                               textFill="#94a3b8" />

                        <Label fx:id="examsSummaryLabel" textFill="#475569" wrapText="true" />

                        <TableView fx:id="examsTable" prefHeight="135.0">
                           <columns>
                              <TableColumn fx:id="colExamTitle"    prefWidth="220.0" text="Exam / Quiz" />
                              <TableColumn fx:id="colExamScore"    prefWidth="90.0"  text="Score" />
                              <TableColumn fx:id="colExamMaxScore" prefWidth="90.0"  text="Max Score" />
                           </columns>
                        </TableView>

                        <BarChart fx:id="examScoreBarChart" prefHeight="210.0" animated="true">
                           <xAxis><CategoryAxis label="Exams" /></xAxis>
                           <yAxis><NumberAxis label="Score (0-100)" lowerBound="0.0" upperBound="100.0" tickUnit="10.0" /></yAxis>
                        </BarChart>
                     </children>
                  </VBox>

               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>

</BorderPane>
