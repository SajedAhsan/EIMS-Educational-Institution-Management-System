<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="14.0" style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 6; -fx-background-radius: 6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
   </padding>
   <children>
      <VBox spacing="10.0" prefWidth="250.0">
         <children>
            <Label text="Discussion Threads">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <ListView fx:id="forumThreadsListView" onMouseClicked="#handleForumThreadSelection" prefHeight="450.0" />
         </children>
      </VBox>
      <VBox spacing="10.0" prefWidth="560.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Messages">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="360.0" vbarPolicy="AS_NEEDED">
               <content>
                  <VBox fx:id="forumMessagesVBox" spacing="8.0" style="-fx-background-color: #f8fafc;">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
            <Label fx:id="forumReplyContextLabel" textFill="#0f766e" />
            <TextArea fx:id="newForumMessageArea" prefHeight="120.0" promptText="Write a message. Use @username to mention someone." wrapText="true" />
            <HBox spacing="8.0">
               <children>
                  <Button onAction="#handlePostForumMessage" prefHeight="34.0" prefWidth="92.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" text="Post" />
                  <Button onAction="#handleCancelForumReply" prefHeight="34.0" prefWidth="92.0" style="-fx-background-color: #64748b; -fx-text-fill: white;" text="Cancel" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>
