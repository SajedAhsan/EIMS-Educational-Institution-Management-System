<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 6; -fx-background-radius: 6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox spacing="4.0" BorderPane.alignment="CENTER_LEFT">
         <padding>
            <Insets bottom="10.0" left="14.0" right="14.0" top="14.0" />
         </padding>
         <children>
            <Label fx:id="unreadMessagesHeaderLabel" text="Unread Messages">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label text="Replies and @mentions for your discussion activity" textFill="#64748b" />
         </children>
      </VBox>
   </top>
   <center>
      <ListView fx:id="unreadMessagesListView" prefHeight="420.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets left="14.0" right="14.0" />
         </BorderPane.margin>
      </ListView>
   </center>
   <bottom>
      <VBox spacing="6.0" style="-fx-background-color: #f8fafc; -fx-border-color: #d7deea; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER_LEFT">
         <padding>
            <Insets bottom="12.0" left="14.0" right="14.0" top="10.0" />
         </padding>
         <children>
            <Label text="Conversation Preview" textFill="#334155">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
            <Label fx:id="messagePreviewThreadLabel" text="Select an unread message to preview" textFill="#475569" />
            <Label fx:id="messagePreviewBodyLabel" textFill="#64748b" wrapText="true" />
         </children>
      </VBox>
   </bottom>
</BorderPane>
