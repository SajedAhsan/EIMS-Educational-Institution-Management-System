<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Student.StudentGroupsListController">
   <children>
      <VBox spacing="12.0" style="-fx-padding: 24;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="My Groups">
               <font>
                  <Font name="System Bold" size="30.0" />
               </font>
            </Label>
            <Label fx:id="statusLabel" style="-fx-background-color: #e3f2fd; -fx-background-radius: 6; -fx-padding: 8 14 8 14;" textFill="#1976d2">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
            <Label text="Select a group to view details and access shared materials" textFill="#666666">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <ListView fx:id="groupsList" onMouseClicked="#handleGroupSelection" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;" VBox.vgrow="ALWAYS" />
            <HBox spacing="12.0">
               <children>
                  <Button fx:id="backButton" onAction="#handleBack" prefHeight="42.0" prefWidth="130.0" style="-fx-background-color: #6c757d; -fx-background-radius: 8;" text="Back" textFill="WHITE">
                     <font>
