                     </font>
                  </Button>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="viewGroupButton" onAction="#handleViewGroup" prefHeight="42.0" prefWidth="220.0" style="-fx-background-color: #0088ff; -fx-background-radius: 8;" text="View Group" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
