<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" style="-fx-background-color: #ffffff; -fx-border-color: #d7deea; -fx-border-radius: 6; -fx-background-radius: 6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
   </padding>
   <children>
      <Label text="Attendance Management">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label text="Mark all Present to start this as a working day. Then you can update attendance individually." textFill="#64748b" wrapText="true" />

      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <children>
            <Label text="Course" />
            <ComboBox fx:id="attendanceCourseCombo" onAction="#handleAttendanceCourseChange" prefWidth="250.0" />
            <Label text="Date" />
            <DatePicker fx:id="attendanceDatePicker" onAction="#handleAttendanceDateChange" prefWidth="150.0" />
            <Button onAction="#handleMarkAllPresent" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold;" text="Mark All Present" />
            <Button onAction="#handleMarkAllAbsent" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold;" text="Mark All Absent" />
            <Button onAction="#handleExportAttendanceCsv" style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold;" text="Export CSV" />
            <Button onAction="#handleRefreshAttendanceView" style="-fx-background-color: #475569; -fx-text-fill: white;" text="Refresh" />
         </children>
      </HBox>

      <Label fx:id="attendanceSummaryLabel" textFill="#334155" />

      <TableView fx:id="attendanceTable" editable="true" prefHeight="330.0" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colAttendanceStudent" prefWidth="280.0" text="Student" />
            <TableColumn fx:id="colAttendanceStatus" prefWidth="260.0" text="Attendance Status" />
         </columns>
      </TableView>

      <BarChart fx:id="attendanceOverviewBarChart" prefHeight="220.0">
         <xAxis>
            <CategoryAxis label="Week" />
         </xAxis>
         <yAxis>
            <NumberAxis label="Class Attendance %" lowerBound="0.0" upperBound="100.0" tickUnit="10.0" />
         </yAxis>
      </BarChart>
   </children>
</VBox>
