<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="800" maxWidth="1200" minHeight="800" minWidth="1200" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Teacher.CreateGroupController">
    <VBox spacing="15" style="-fx-padding: 25;" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        
        <!-- Title -->
        <Label text="Create New Group" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f5576c;">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>
        
        <!-- Group Name Section -->
        <VBox spacing="8">
            <Label text="Group Name:" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <TextField fx:id="groupNameField" promptText="Enter group name" style="-fx-font-size: 13px; -fx-padding: 10;" prefHeight="40"/>
        </VBox>
        
        <!-- Search Section -->
        <VBox spacing="8">
            <Label text="Search Students:" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search by name or email" style="-fx-font-size: 13px; -fx-padding: 10;" prefHeight="40" HBox.hgrow="ALWAYS"/>
                <Button fx:id="searchButton" onAction="#handleSearchStudents" text="Search" style="-fx-font-size: 13px; -fx-padding: 10 20 10 20; -fx-background-color: #0088ff; -fx-text-fill: white;" prefHeight="40" prefWidth="100"/>
            </HBox>
        </VBox>
        
        <!-- Students Lists Section -->
        <HBox spacing="15" VBox.vgrow="ALWAYS">
            <!-- Available Students -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Available Students:" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <ListView fx:id="availableStudentsList" style="-fx-font-size: 12px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"/>
            </VBox>
            
            <!-- Add/Remove Buttons -->
            <VBox spacing="10" alignment="CENTER">
                <Button fx:id="addButton" onAction="#handleAddStudent" text="Add" style="-fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" prefHeight="40" prefWidth="65"/>
                <Button fx:id="removeButton" onAction="#handleRemoveStudent" text="Remove" style="-fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" prefHeight="40" prefWidth="65"/>
            </VBox>
            
            <!-- Selected Students -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Selected Students:" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <ListView fx:id="selectedStudentsList" style="-fx-font-size: 12px; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>
        
        <!-- Status Label -->
        <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-text-fill: #0088ff;">
            <VBox.margin>
                <Insets top="5"/>
            </VBox.margin>
        </Label>
        
        <!-- Buttons -->
        <HBox spacing="15">
            <Button fx:id="backButton" onAction="#handleBack" text="← Back" style="-fx-font-size: 13px; -fx-padding: 12 25 12 25; -fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 8;" prefHeight="45" prefWidth="130"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="createGroupBtn" onAction="#handleCreateGroup" text="Create Group" style="-fx-font-size: 14px; -fx-padding: 12 30 12 30; -fx-background-color: #0088ff; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" prefHeight="45" prefWidth="180"/>
        </HBox>
    </VBox>
</AnchorPane>
